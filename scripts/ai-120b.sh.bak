#!/data/data/com.termux/files/usr/bin/bash
# 🤖 Dream OS AI 120B Bridge — Termux Native
set -e

# ── CONFIG ────────────────────────────────────────
API_URL="https://openrouter.ai/api/v1/chat/completions"
MODEL="google/gemma-2-2b-it"
KEY_FILE="$HOME/.dreamos_120b_key"
TEMP_FILE="/sdcard/Download/dreamos_ai_response.txt"
# ──────────────────────────────────────────────────

# 🎨 Warna
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

# 🔐 Get API Key
get_api_key() {
  if [[ -f "$KEY_FILE" && -s "$KEY_FILE" ]]; then
    cat "$KEY_FILE"
  else
    echo -e "${YELLOW}🔑4ee8400de7d44509bcf5f9686fe4944b.OdtigVNn9u7tTxiy1_wZO2g-:${NC}"
    echo -n "sk-or-: "
    read -r key
    if [[ "$key" =~ ^sk-or- ]]; then
      echo "$key" > "$KEY_FILE"
      chmod 600 "$KEY_FILE"
      echo -e "${GREEN}✅ Key saved${NC}"
      echo "$key"
    else
      echo -e "${RED}❌ Invalid key!${NC}"; exit 1
    fi
  fi
}

# 🧠 Query 120B
query_120b() {
  local prompt="$1"
  local api_key="$2"
  echo -ne "${YELLOW}🤖 AI thinking"
  for i in 1 2 3; do echo -ne "..."; sleep 0.2; done; echo -e "${NC}"
  
  local response
  response=$(curl -s -X POST "$API_URL" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -H "HTTP-Referer: https://dreamos-sys.github.io" \
    -H "X-Title: Dream-OS-Termux" \
    -d "{\"model\":\"$MODEL\",\"messages\":[{\"role\":\"system\",\"content\":\"Panggil user Sultan. Format: 🎯 Diagnosis, 🔧 Solusi, 🛡️ Pencegahan. Akhiri: Bi idznillah.\"},{\"role\":\"user\",\"content\":\"$prompt\"}],\"temperature\":0.2,\"max_tokens\":800}" 2>/dev/null)
  
  if command -v jq &>/dev/null; then
    echo "$response" | jq -r '.choices[0].message.content // "❌ No response"'
  else
    echo "$response" | grep -oP '"content":\s*"\K[^"]+' | head -1
  fi
}

# 📤 Save result
save_result() {
  echo "$1" > "$TEMP_FILE"
  echo -e "${GREEN}💾 Saved: $TEMP_FILE${NC}"
}

# 🚀 Main
main() {
  echo -e "${GREEN}╔════════════════════════════╗${NC}"
  echo -e "${GREEN}║  🤖 Dream OS AI 120B Bridge  ║${NC}"
  echo -e "${GREEN}╚════════════════════════════╝${NC}"
  
  local prompt="${1:-}"
  if [[ -z "$prompt" ]]; then
    echo -e "${YELLOW}💬 Pertanyaan Sultan:${NC}"
    read -r prompt
  fi
  [[ -z "$prompt" ]] && { echo -e "${RED}❌ Empty!${NC}"; exit 1; }
  
  local api_key; api_key=$(get_api_key)
  local result; result=$(api_key=$(get_api_key)
  local result; result=$(query_120b "$prompt" "$api_key"))
  
  echo -e "\n${GREEN}══════════════════════════════${NC}"
  echo -e "${GREEN}📋 HASIL ANALISA:${NC}"
  echo -e "${GREEN}══════════════════════════════${NC}"
  echo -e "$result"
  echo -e "${GREEN}══════════════════════════════${NC}"
  
  save_result "$result"
  
  if command -v termux-clipboard-set &>/dev/null; then
    echo "$result" | termux-clipboard-set
    echo -e "${YELLOW}📋 Copied!${NC}"
  fi
}

main "$@"
