#!/data/data/com.termux/files/usr/bin/bash

case "$1" in
  "/v-spider")
    target="${2:-127.0.0.1}"
    # Validasi input: Jangan mau kalau cuma 'scan' atau kata-kata ngaco
    if [[ "$target" == "scan" || ! "$target" =~ [0-9] && "$target" != "localhost" && ! "$target" == *"."* ]]; then
       echo "❌ Error: Target harus IP atau URL valid!" >&2
       exit 1
    fi
    echo "🕵️ V-Spider: Merayap ke $target..."
    python3 ~/dream-live/modules/spider_venom.py "$target"
    ;;

  "/radar")
    bash ~/dream-live/modules/tail_radar.sh
    ;;

  "/dream-shield")
    sub="${2:-status}"
    case "$sub" in
      "status")
        echo "🛡️ DREAM SHIELD STATUS — $(date '+%Y-%m-%d %H:%M')"
        echo "--------------------------------------------------"
        pgrep -f stealth_launcher >/dev/null 2>&1 && echo "🔐 Stealth: ✅ Aktif" || echo "🔐 Stealth: ❌ Nonaktif"
        pgrep -f tailscaled >/dev/null 2>&1 && echo "📡 Radar: ✅ Aktif" || echo "📡 Radar: ❌ Offline"
        pgrep -f honeypot >/dev/null 2>&1 && echo "🕵️ Honeypot: ✅ Aktif" || echo "🕵️ Honeypot: ❌ Nonaktif"
        echo "📊 Logs: $(wc -c < ~/dream-live/logs/blocked_ips.log 2>/dev/null || echo 0)B blocked"
        ;;
      *) echo "Usage: mr /dream-shield [status]" >&2 ;;
    esac
    ;;

  *)
    echo "🕶️ Dream OS CLI — Usage: mr <command> [args]" >&2
    echo "Available: /v-spider /radar /dream-shield" >&2
    ;;
esac
