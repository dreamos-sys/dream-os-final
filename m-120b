#!/data/data/com.termux/files/usr/bin/bash
case "$1" in
  "/multitester")
    target="${2:-127.0.0.1}"
    mode="${3:-quick}"
    echo "🤲 Konfirmasi: Audit sistem sendiri? (y/n)" >&2
    read -r confirm < /dev/tty
    [ "$confirm" != "y" ] && { echo "❌ Dibatalkan." >&2; exit 1; }
    python3 ~/dream-live/modules/multitester.py "$target" "$mode"
    ;;
  "/dream-shield")
    sub="${2:-status}"
    case "$sub" in
      "status")
        echo "🛡️  DREAM SHIELD STATUS — $(date '+%Y-%m-%d %H:%M')"
        echo "--------------------------------------------------"
        pgrep -f stealth_launcher >/dev/null && echo "🔐 Stealth: ✅ Aktif" || echo "🔐 Stealth: ❌ Nonaktif"
        grep -q "flask_limiter" ~/dream-live/server_flask.py 2>/dev/null && echo "🛑 Rate Limit: ✅ Terpasang" || echo "🛑 Rate Limit: ❌ Belum"
        pgrep -f honeypot.py >/dev/null && echo "🕵️  Honeypot: ✅ Aktif" || echo "🕵️  Honeypot: ❌ Nonaktif"
        echo "📊 Logs: $(wc -c < ~/dream-live/logs/blocked_ips.log 2>/dev/null || echo 0)B blocked | $(wc -c < ~/dream-live/logs/honeypot.json 2>/dev/null || echo 0)B honeypot"
        echo "🤲 Bi idznillah — Niat lurus, sistem terjaga."
        ;;
      "start")
        echo "🚀 Starting Dream Shield..."
        python3 ~/dream-live/modules/honeypot.py >/dev/null 2>&1 &
        python3 ~/dream-live/modules/stealth_launcher.py >/dev/null 2>&1 &
        echo "✅ Layers started. Bi idznillah."
        ;;
      "stop")
        echo "🛑 Stopping Dream Shield..."
        pkill -f honeypot.py 2>/dev/null; pkill -f stealth_launcher 2>/dev/null
        echo "✅ Layers stopped. Bi idznillah."
        ;;
      "logs")
        echo "📋 Last 3 blocked IPs:"; tail -3 ~/dream-live/logs/blocked_ips.log 2>/dev/null || echo "   (none)"
        echo "📋 Last 3 honeypot hits:"; tail -3 ~/dream-live/logs/honeypot.json 2>/dev/null || echo "   (none)"
        ;;
      "monitor")
        echo "🔄 Starting Dream Shield Monitor (Ctrl+C to stop)"
        python3 ~/dream-live/modules/dream_shield.py monitor
        ;;
      *)
        echo "Usage: mr /dream-shield [status|start|stop|logs|monitor]" >&2
        ;;
    esac
    ;;
  *)
    echo "🕶️ Dream OS CLI — Usage: mr <command> [args]" >&2
    echo "Available: /multitester /dream-shield" >&2
    ;;
esac
