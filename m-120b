agent_query() {
  local task="$1"
  echo "🤖 Agent: $task" >&2
  
  if [ "$(check_backend)" = "yes" ]; then
    # Call API + capture response
    local resp
    resp=$(curl -s -X POST "$API_BASE/api/agent" \
      -H "Content-Type: application/json" \
      -d "{\"task\":\"$task\"}" 2>/dev/null)
    
    # Parse JSON output field dengan sed (no jq dependency)
    if echo "$resp" | grep -q '"output"'; then
      echo "$resp" | sed -n 's/.*"output"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
    else
      # Fallback: tampilkan raw response
      echo "$resp"
    fi
  else
    echo "⚠️ Backend offline at $API_BASE" >&2
  fi
}

# Simple review command
cmd_review() {
  echo "🔍 Review: $1" >&2
  [ -f "$1" ] && wc -l "$1" || echo "File not found"
}

