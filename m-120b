#!/data/data/com.termux/files/usr/bin/bash
# Dream OS CLI Router v4.0 — Modular Architecture
DREAM_ROOT="${HOME}/dream-live"
MODULES="${DREAM_ROOT}/modules"

# Auto-load modules
for mod in "${MODULES}"/*.sh; do [ -f "$mod" ] && source "$mod"; done

# Simple router
case "$1" in
  "/ship") deploy_task "$2" ;;
  "/status") check_status ;;
  "/agent") 
    # Forward to Flask backend
    curl -s -X POST "http://127.0.0.1:8082/api/agent" \
      -H "Content-Type: application/json" \
      -d "{\"task\":\"$2\"}" 2>/dev/null | sed -n 's/.*"output"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
    ;;
  *) 
    echo "╔════════════════╗"; echo "║ 🕶️ Mr. M v4.0 ║"; echo "╚════════════════╝" >&2
    echo "Usage: $0 {/agent|/ship|/status} [args]" >&2 
    ;;
esac
