#!/data/data/com.termux/files/usr/bin/bash
# 🕶️ SMART MR. M v3.6 — Context-Aware AI Agent for Dream OS
# Usage: ./m-120b [/review|/spec|/fix|/pray] [target]

set -e

# ── CONFIG ────────────────────────────────────────
DREAM_ROOT="$HOME/dream-live"
DOCS_DIR="$DREAM_ROOT/docs"
API_BASE="${DREAMOS_API:-http://localhost:8082}"  # Bisa di-override ke tunnel URL
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
# ──────────────────────────────────────────────────

# 🔍 Helper: Cek apakah backend AI available
check_backend() {
  curl -s --max-time 3 "$API_BASE/" >/dev/null 2>&1 && echo "✅" || echo "❌"
}

# 📚 Helper: Autoresearch-lite — baca docs relevan
autoresearch() {
  local topic="$1"
  echo -e "${BLUE}🔍 Autoresearch: '$topic'${NC}" >&2
  
  # Cari di docs/
  if [ -d "$DOCS_DIR" ]; then
    grep -ril "$topic" "$DOCS_DIR" --include="*.md" --include="*.json" 2>/dev/null | head -3 | while read f; do
      echo "   → $(basename $f)" >&2
    done
  fi
  
  # Cek API spec kalau ada
  if [ -f "$DOCS_DIR/api-spec.json" ]; then
    grep -o "\"$topic\"[^}]*" "$DOCS_DIR/api-spec.json" 2>/dev/null | head -1 | sed 's/^/   📋 /' >&2 || true
  fi
}

# 🧠 Helper: Forward ke AI backend (kalau available)
ask_ai() {
  local prompt="$1"
  local backend_status=$(check_backend)
  
  if [ "$backend_status" = "✅" ]; then
    echo -e "${BLUE}🤖 Asking AI backend...${NC}" >&2
    curl -s -X POST "$API_BASE/api/ai/diagnose" \
      -H "Content-Type: application/json" \      -d "{\"query\":\"Mr. M says: $prompt\"}" \
      | jq -r '.response // .error // "❌ No response"' 2>/dev/null
  else
    echo -e "${YELLOW}⚠️ Backend offline. Using local heuristics.${NC}" >&2
    # Fallback: simple pattern matching
    case "$prompt" in
      *"console.log"*) echo "💡 Tip: Remove console.log before production";;
      *"import"*) echo "💡 Tip: Ensure all imports use relative paths";;
      *"module"*) echo "💡 Tip: Keep modules <500 lines (Rule of 500)";;
      *) echo "✅ Local check passed. Bi idznillah.";;
    esac
  fi
}

# 🎯 Command: /review — Smart Code Review
cmd_review() {
  local target="${1:-.}"
  echo -e "${GREEN}╔════════════════════════════╗${NC}"
  echo -e "${GREEN}║  🕶️ Mr. M: Smart Review    ║${NC}"
  echo -e "${GREEN}╚════════════════════════════╝${NC}" >&2
  
  # Autoresearch context
  autoresearch "module"
  autoresearch "API"
  
  # Scan target
  echo -e "\n${YELLOW}📁 Scanning: $target${NC}" >&2
  
  # Check 1: File size (Rule of 500 lines)
  if [ -f "$target" ]; then
    lines=$(wc -l < "$target" 2>/dev/null || echo 0)
    if [ "$lines" -gt 500 ]; then
      echo -e "${RED}🚨 COMPLEXITY: $target has $lines lines (limit: 500)${NC}" >&2
    else
      echo -e "${GREEN}✅ SIZE: $target ($lines lines)${NC}" >&2
    fi
  fi
  
  # Check 2: console.log leaks
  if grep -q "console.log" "$target" 2>/dev/null; then
    echo -e "${YELLOW}⚠️ DEBUG: console.log found in $target${NC}" >&2
  fi
  
  # Check 3: Import paths
  if grep -q "from '" "$target" 2>/dev/null; then
    if grep "from '" "$target" | grep -qv "^\.\./\|^\./"; then
      echo -e "${YELLOW}⚠️ IMPORT: Non-relative import detected${NC}" >&2
    else
      echo -e "${GREEN}✅ IMPORT: All paths relative${NC}" >&2
    fi  fi
  
  # Ask AI for final insight
  echo -e "\n${BLUE}🧠 AI Insight:${NC}" >&2
  local insight=$(ask_ai "Review $target for Dream OS v3.6 standards: modular, slim, spiritual.")
  echo -e "$insight" | sed 's/^/   /' >&2
  
  echo -e "\n${GREEN}✅ Review complete. Bi idznillah.${NC}" >&2
}

# 📋 Command: /spec — Auto-Generate Spec Docs
cmd_spec() {
  local feature="${1:-New Module}"
  echo -e "${GREEN}╔════════════════════════════╗${NC}"
  echo -e "${GREEN}║  📋 Mr. M: Spec Generator  ║${NC}"
  echo -e "${GREEN}╚════════════════════════════╝${NC}" >&2
  
  autoresearch "spec"
  
  # Generate spec skeleton
  local spec_file="$DOCS_DIR/specs/$(echo "$feature" | tr ' ' '-' | tr 'A-Z' 'a-z').md"
  mkdir -p "$(dirname "$spec_file")"
  
  cat << SPEC > "$spec_file"
# 📋 Spec: $feature
*Generated by Mr. M v3.6 • $(date +%Y-%m-%d)*

## 🎯 Objective
$feature

## 🔌 API Contract
\`\`\`json
{
  "endpoint": "/api/$(echo "$feature" | tr ' ' '-' | tr 'A-Z' 'a-z')",
  "method": "GET|POST",
  "request": {},
  "response": {}
}
\`\`\`

## 🧩 Module Structure
\`\`\`
workspaces/kabag_umum/modules/$(echo "$feature" | tr ' ' '-' | tr 'A-Z' 'a-z')/
├── module.js      # Main logic (<500 lines)
├── config/        # Rules, constants
└── README.md      # Usage docs
\`\`\`

## ✅ Acceptance Criteria
- [ ] Module loads via dynamic import- [ ] UI renders in <100ms
- [ ] Error handling with user feedback
- [ ] Spiritual note: "Bi idznillah" in commit msg

## 🔐 Security Checklist
- [ ] No hardcoded secrets
- [ ] Input validation on all endpoints
- [ ] CORS configured for PWA origin
SPEC

  echo -e "${GREEN}✅ Spec generated: $spec_file${NC}" >&2
  echo -e "${YELLOW}💡 Next: Run \`./m-120b /review $spec_file\` to validate${NC}" >&2
}

# 🔧 Command: /fix — Auto-Suggest Fixes
cmd_fix() {
  local issue="${1:-code quality}"
  echo -e "${GREEN}╔════════════════════════════╗${NC}"
  echo -e "${GREEN}║  🔧 Mr. M: Fix Suggester   ║${NC}"
  echo -e "${GREEN}╚════════════════════════════╝${NC}" >&2
  
  autoresearch "fix"
  
  echo -e "\n${YELLOW}🔍 Analyzing: '$issue'${NC}" >&2
  local suggestion=$(ask_ai "Suggest fix for Dream OS issue: $issue. Keep it Termux-compatible, modular, spiritual.")
  echo -e "\n${GREEN}💡 Suggestion:${NC}" >&2
  echo -e "$suggestion" | sed 's/^/   /' >&2
  
  echo -e "\n${GREEN}✅ Fix suggestion ready. Bi idznillah.${NC}" >&2
}

# 🕌 Command: /pray — Spiritual Context + Prayer Times
cmd_pray() {
  echo -e "${GREEN}╔════════════════════════════╗${NC}"
  echo -e "${GREEN}║  🕌 Mr. M: Spiritual Mode  ║${NC}"
  echo -e "${GREEN}╚════════════════════════════╝${NC}" >&2
  
  # Fetch prayer times via backend
  if [ "$(check_backend)" = "✅" ]; then
    local prayer=$(curl -s "$API_BASE/api/prayer" 2>/dev/null | jq -r '.prayers.maghrib // "N/A"')
    echo -e "${BLUE}🕌 Maghrib today: $prayer${NC}" >&2
  else
    echo -e "${YELLOW}⚠️ Backend offline. Using fallback: Maghrib ~18:00${NC}" >&2
  fi
  
  # Spiritual reminder
  echo -e "\n${GREEN}✨ Reminder:${NC}" >&2
  echo -e "   \"Setiap baris kode yang ditulis dengan niat lurus, adalah ibadah.\" — Mr. M" >&2
  echo -e "   \"Bi idznillah — Dengan izin Allah, Dream OS memberi manfaat.\" ✨" >&2
    echo -e "\n${GREEN}✅ Spiritual context loaded. Bi idznillah.${NC}" >&2
}

# 🚀 Main Router
main() {
  local cmd="${1:-}"
  shift 2>/dev/null || true
  
  case "$cmd" in
    "/review") cmd_review "$@";;
    "/spec")   cmd_spec "$@";;
    "/fix")    cmd_fix "$@";;
    "/pray")   cmd_pray;;
    *)
      # Default: Pre-flight check + smart summary
      echo -e "${GREEN}╔════════════════════════════╗${NC}"
      echo -e "${GREEN}║  🕶️ Mr. M v3.6: Sovereign  ║${NC}"
      echo -e "${GREEN}╚════════════════════════════╝${NC}" >&2
      
      echo -e "\n${BLUE}🔍 Sovereign Standards Check:${NC}" >&2
      
      # Check API spec
      if [ -f "$DOCS_DIR/api-spec.json" ]; then
        echo -e "${GREEN}✅ API Contract: Found${NC}" >&2
      else
        echo -e "${RED}❌ API Contract: Missing${NC}" >&2
      fi
      
      # Check module sizes
      local fat=$(find "$DREAM_ROOT" -name "*.js" -size +5k -not -path "*/node_modules/*" 2>/dev/null | wc -l)
      if [ "$fat" -eq 0 ]; then
        echo -e "${GREEN}✅ Code Size: All modules slim${NC}" >&2
      else
        echo -e "${YELLOW}⚠️ Code Size: $fat file(s) >5KB${NC}" >&2
      fi
      
      # Check backend
      local backend=$(check_backend)
      if [ "$backend" = "✅" ]; then
        echo -e "${GREEN}✅ AI Backend: Online ($API_BASE)${NC}" >&2
      else
        echo -e "${YELLOW}⚠️ AI Backend: Offline (local-only mode)${NC}" >&2
      fi
      
      echo -e "\n${BLUE}📋 Available Commands:${NC}" >&2
      echo -e "   ./m-120b /review [file]   → Smart code review" >&2
      echo -e "   ./m-120b /spec [feature]  → Auto-generate spec docs" >&2
      echo -e "   ./m-120b /fix [issue]     → Get fix suggestions" >&2
      echo -e "   ./m-120b /pray            → Spiritual context + prayer times" >&2
            echo -e "\n${GREEN}✅ Pre-flight complete. Bi idznillah.${NC}" >&2
      ;;
  esac
}

main "$@"
