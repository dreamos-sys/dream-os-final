# ── AI AGENT ENDPOINT ──────────────────────────────
@app.route("/api/agent", methods=["POST"])
def agent_endpoint():
    try:
        data = request.get_json()
        if not data or "task" not in data:
            return jsonify({"success": False, "error": "Missing 'task'"}), 400
        # Simple echo response untuk test dulu
        return jsonify({"success": True, "output": f"Agent received: {data['task']}", "audit_id": 0})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)}), 500

@app.route("/api/agent/status", methods=["GET"])
def agent_status():
    return jsonify({"status": "online", "version": "1.0.0"})
