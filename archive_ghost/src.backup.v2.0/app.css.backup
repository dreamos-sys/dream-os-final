/* Dream OS - Crystal Glassmorphism Design System */
:root {
  /* Background - Global Standard Light */
  --bg-primary: #f8fafc;
  --bg-secondary: #ffffff;
  --bg-gradient-start: #f0f9ff;
  --bg-gradient-end: #f0fdf4;
  
  /* Glassmorphism */
  --glass-bg: rgba(255, 255, 255, 0.7);
  --glass-border: rgba(255, 255, 255, 0.5);
  --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
  --glass-blur: blur(12px);
  
  /* Brand Colors - Emerald Crystal */
  --primary: #10b981;
  --primary-light: #6ee7b7;
  --primary-gradient: linear-gradient(135deg, #10b981 0%, #06b6d4 100%);
  
  /* Text - WCAG AA Compliant */
  --text-primary: #1e293b;
  --text-secondary: #64748b;
  --text-contrast: 4.5;
  
  /* iOS-style Shadows */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  --shadow-crystal: 0 20px 40px -5px rgba(16, 185, 129, 0.15);
}

/* Dark mode support (optional) */
@media (prefers-color-scheme: dark) {
  :root {
    --bg-primary: #0f172a;
    --bg-secondary: #1e293b;
    --glass-bg: rgba(30, 41, 59, 0.7);
    --glass-border: rgba(255, 255, 255, 0.1);
  }
}

body {
  background: linear-gradient(135deg, 
    var(--bg-gradient-start) 0%, 
    var(--bg-gradient-end) 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Crystal Glassmorphism Card */
.crystal-card {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  border-radius: 24px;
  box-shadow: var(--glass-shadow), var(--shadow-crystal);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.crystal-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 25px 50px -12px rgba(16, 185, 129, 0.2);
}

/* iOS-style Button */
.crystal-button {
  background: var(--primary-gradient);
  color: white;
  border: none;
  border-radius: 16px;
  padding: 16px 32px;
  font-weight: 600;
  font-size: 16px;
  box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
  transition: all 0.3s ease;
}

.crystal-button:active {
  transform: scale(0.98);
  box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
}

/* Crystal Icon Container */
.crystal-icon {
  width: 56px;
  height: 56px;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
}

.crystal-icon:hover {
  transform: scale(1.05);
  box-shadow: var(--shadow-crystal);
}

/* Smooth Scroll */
html {
  scroll-behavior: smooth;
}

/* Focus Visible - Accessibility */
:focus-visible {
  outline: 3px solid var(--primary);
  outline-offset: 2px;
}
