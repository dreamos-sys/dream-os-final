<script>
  import { onMount } from 'svelte';
  import { aria } from '$lib/config/accessibility.js';
  
  export let config = {};
  export let utils = {};
  export let supabase = null;
  export let currentUser = null;
  
  let systemStatus = {
    bookings: 'SISTEM OK',
    security: 'AMAN',
    lastUpdate: new Date().toLocaleTimeString('id-ID')
  };
  
  function announce(msg) {
    const el = document.getElementById('a11y-announcer');
    if (el) { el.textContent = msg; }
  }
  
  function refreshSystem() {
    announce('Refreshing system...');
    systemStatus.lastUpdate = new Date().toLocaleTimeString('id-ID');
    setTimeout(() => announce('System refreshed'), 1000);
  }
  
  onMount(() => {
    announce('Command Center loaded');
  });
</script>

