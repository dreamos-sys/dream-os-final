{
  "version": "1.0",
  "local": {
    "models": [
      {
        "id": "phi3-mini-ollama",
        "source": "ollama",
        "model": "tinyllama",
        "size": "~2GB",
        "task": "chat",
        "runtime": "ollama-api",
        "priority": 1,
        "endpoint": "http://localhost:11434/api/generate"
      }
    ],
    "runtimes": {
      "ollama-api": {
        "installed": true,
        "endpoint": "http://localhost:11434",
        "timeout": 30000
      }
    }
  },
  "online": {
    "ollama": {
      "enabled": true,
      "endpoint": "http://localhost:11434",
      "models": ["tinyllama"],
      "priority": 1
    }
  },
  "fallbackChain": ["phi3-mini-ollama"],
  "privacyRules": {
    "sensitiveKeywords": ["password", "rahasia", "npwp", "rekening", "token"],
    "forceLocal": true
  }
}
