#!/bin/bash
echo "🧠 Dream AI Chat (Ctrl+C to exit)"
echo "=================================="
while true; do
  echo -n "You: "
  read prompt
  [ -z "$prompt" ] && continue
  echo -n "AI: "
  curl -s http://localhost:11434/api/generate \
    -H "Content-Type: application/json" \
    -d "{\"model\":\"phi3:mini\",\"prompt\":\"$prompt\",\"stream\":false}" \
    | grep -o '"response":"[^"]*"' | cut -d'"' -f4 | sed 's/\\n/\n/g'
  echo ""
done
