{
  "openapi": "3.0.0",
  "info": {
    "title": "Dream OS Sovereign API",
    "version": "1.0.0",
    "description": "API Kontrak untuk Modul K3 dan Maintenance Sultan"
  },
  "paths": {
    "/workspaces/k3/report": {
      "post": {
        "summary": "Submit K3 Incident Report",
        "tags": ["Safety"],
        "responses": {
          "201": { "description": "Laporan Berhasil Disimpan" },
          "403": { "description": "Akses Ditolak (Level Kedaulatan Rendah)" }
        }
      }
    },
    "/workspaces/maintenance/task": {
      "get": {
        "summary": "Get Maintenance Task List",
        "tags": ["Facility"],
        "responses": {
          "200": { "description": "Data Perbaikan Ditemukan" }
        }
      }
    }
  }
}
